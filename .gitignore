# =============================================================================
# Closira — Root .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Backend — database & logs
# -----------------------------------------------------------------------------
backend/closira.db
backend/*.db
backend/*.sqlite
backend/*.sqlite3
backend/app/logs/
backend/**/*.log
backend/**/*.log.*

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env/
backend/.venv/
backend/venv/

# -----------------------------------------------------------------------------
# Environment variables
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# -----------------------------------------------------------------------------
# Distribution / packaging
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
.pytest_cache/
**/.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
test-results/

# -----------------------------------------------------------------------------
# Type checking
# -----------------------------------------------------------------------------
.mypy_cache/
**/.mypy_cache/
.dmypy.json
.pyright/

# -----------------------------------------------------------------------------
# IDEs & editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Desktop.ini
$RECYCLE.BIN/
Thumbs.db

# -----------------------------------------------------------------------------
# Secrets & credentials
# -----------------------------------------------------------------------------
*.pem
*.key
*.cert
*.p12
secrets/
credentials/